#!/usr/bin/env bash
# Pre-fill the commit message with a Claude-generated subject.

log_file="${XDG_STATE_HOME:-$HOME/.local/state}/git/prepare-commit-msg.log"
log_max=$((256 * 1024))                           # past this the log rotates to a .1 backup, so it stays bounded
repo=$(git rev-parse --show-toplevel 2>/dev/null) # one log file serves every repo, so record which

# best-effort: a logging failure must never block the commit
log() {
    local size=0
    mkdir -p "${log_file%/*}" 2>/dev/null || return 0
    [ -f "$log_file" ] && size=$(wc -c <"$log_file" 2>/dev/null) # guard the read: an absent log must not leak an open error past 2>/dev/null
    # rotate by rename past the cap: atomic, so a parallel commit can't lose
    # lines, and a fresh log just starts the count over.
    [ "${size:-0}" -gt "$log_max" ] && mv -f "$log_file" "$log_file.1" 2>/dev/null
    printf '%s [%s] %s\n' "$(date '+%F %T')" "${repo:-?}" "$*" >>"$log_file" 2>/dev/null || true
}

# Never override a repo's own hook: core.hooksPath routes every repo here, so
# hand off to a repo-local hook when one exists. --git-common-dir finds the
# shared hooks dir (worktree-safe); -ef stops us handing off to ourselves.
local_hook="$(git rev-parse --git-common-dir 2>/dev/null)/hooks/prepare-commit-msg"
if [ -x "$local_hook" ] && ! [ "$local_hook" -ef "$0" ]; then
    log "handoff to repo hook: $local_hook"
    exec "$local_hook" "$@"
fi

[ -n "$2" ] && {
    log "skip: message source ($2)"
    exit 0
} # $2 is set for -m/template/merge/squash/amend
[ -n "$NO_AI_COMMIT" ] && {
    log "skip: NO_AI_COMMIT set"
    exit 0
}
command -v claude >/dev/null 2>&1 || {
    log "skip: claude not on PATH"
    exit 0
}

exclude_globs=(
    ':(exclude)*-lock.json' # npm
    ':(exclude)*.lock.json' # nuget (packages.lock.json)
    ':(exclude)*-lock.yaml' # pnpm
    ':(exclude)*.lock'      # yarn, cargo, poetry, composer, gem, ...
    ':(exclude)go.sum'
    ':(exclude)*.min.js' ':(exclude)*.min.css' ':(exclude)*.map' # build output
)

diff=$(git diff --cached --function-context -- . "${exclude_globs[@]}")
[ -z "$diff" ] && {
    log "skip: empty staged diff (after exclusions)"
    exit 0
}

# A large refactor can still overflow the window without any lock files. Past a
# size budget (rough proxy for tokens) fall back to a --stat summary: always
# small, still enough to write a subject.
diff_budget=$((64 * 1024))
if [ "${#diff}" -gt "$diff_budget" ]; then
    log "diff too large (${#diff} > $diff_budget); using --stat summary"
    diff=$(git diff --cached --stat -- . "${exclude_globs[@]}")
fi

recent=$(git log -n 20 --pretty=format:'%s' 2>/dev/null) # style examples for the prompt

instructions="Write a single commit message line for the staged diff piped on stdin.
Use Conventional Commits: type(scope): description. type is one of feat, fix, chore, refactor, docs, style, perf, test. scope is the area changed, e.g. nvim, bash, or a plugin name.
Keep the description lowercase, imperative, no trailing period, under ~70 characters. Output only the line: no quotes, no code fences, no explanation.
Match the style of these recent subjects:
$recent"

# Strip all that isn't needed to emit one line, for fast startup and fewer
# tokens: our system prompt replaces the default, and tools, auto memory, and
# MCP are off (--strict-mcp-config for local servers, the env var for claude.ai-
# hosted). None of this drops auth, unlike --bare.
export CLAUDE_CODE_DISABLE_AUTO_MEMORY=1 ENABLE_CLAUDEAI_MCP_SERVERS=false

claude_args=(
    --model haiku
    --strict-mcp-config --mcp-config '{"mcpServers":{}}'
    --tools ""
    --system-prompt "$instructions"
    -p
)

err=$(mktemp 2>/dev/null || echo /dev/null) # capture stderr so a failure is logged, not swallowed
trap '[ "$err" != /dev/null ] && rm -f "$err"' EXIT
msg=$(printf '%s' "$diff" | timeout 3m claude "${claude_args[@]}" 2>"$err")
status=$?
if [ "$status" -ne 0 ]; then # 124 = timeout; others are claude/auth/network errors
    detail=$(printf '%s %s' "$msg" "$(cat "$err" 2>/dev/null)" | tr '\n' ' ' | cut -c1-500)
    log "claude failed (exit $status): $detail"
    exit 0
fi

# models sometimes fence or quote the line; take the first real line, unwrapped
msg=$(printf '%s\n' "$msg" |
    grep -v '^[[:space:]]*```' |
    grep -m1 '[^[:space:]]' |
    sed -E "s/^[[:space:]\"'\`]+//; s/[[:space:]\"'\`]+\$//")
[ -z "$msg" ] && {
    log "claude returned no usable line"
    exit 0
}

printf '%s\n\n%s' "$msg" "$(cat "$1")" >"$1" # prepend; keep git's template/comments below
log "ok: $msg"
exit 0
